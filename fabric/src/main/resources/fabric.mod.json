{
    "schemaVersion": 1,
    "id": "linglens",
    "version": "${version}",
    "name": "LingLens",
    "description": "LingLens提供 离线玩家传送、性能监控、实体统计、聊天缓存、玩家查询 等实用功能。\nLingLens provides practical features such as offline player teleportation, performance monitoring, entity statistics, chat caching, and player queries.",
    "authors": [
        "lin-lin-miao"
    ],
    "contact": {
        "homepage": "https://lh.linglinmiao.fun/",
        "sources": "https://github.com/lin-lin-miao/LingLens-MCmod"
    },
    "license": "CC0-1.0",
    "icon": "assets/linglens/icon.png",
    "environment": "*",
    "entrypoints": {
        "main": [
            "com.linglens.fabric.LingLensModMainFabric"
        ],
        "client": [
            "com.linglens.fabric.client.LingLensFabricClient"
        ]
    },
    "mixins": [
        "linglens.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=0.19.3",
        "minecraft": "~1.20.1",
        "java": ">=17",
        "fabric-api": "*"
    },
    "suggests": {
        "another-mod": "*"
    }
}